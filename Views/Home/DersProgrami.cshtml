@model List<ZeynepsNotebook.Models.DersProgramiItem>

@{
    ViewData["Title"] = "Ders Programım";
    // Günleri sırayla listelemek için bir dizi oluşturuyoruz
    var gunler = new List<string> { "Pazartesi", "Salı", "Çarşamba", "Perşembe", "Cuma", "Cumartesi", "Pazar" };
}

<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@600&family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Nunito', sans-serif;
        color: #4a4a4a;
        background-image: url('/images/calisma.jpg?v=1') !important;
        background-size: cover !important;
        background-position: center !important;
        background-attachment: fixed !important;
    }

    .sayfa-baslik {
        font-family: 'Caveat', cursive;
        font-size: 4rem;
        color: #ff8b94;
        text-shadow: 2px 2px 5px rgba(0,0,0,0.1);
    }

    .ekleme-kutusu {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 25px;
        border: 2px dashed #fbc2eb;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    ..gun-karti {
        background: rgba(255, 255, 255, 0.85); /* Arka plan hafifçe görünsün diye şeffaflık verdik */
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 25px;
        border-top: 5px solid #a6c1ee;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .gun-karti:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
        }

    .gun-baslik {
        font-family: 'Caveat', cursive;
        font-size: 2.2rem;
        color: #8fa0c9;
        border-bottom: 2px dashed #eee;
        padding-bottom: 10px;
        margin-bottom: 15px;
    }

    .ders-satiri {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fafafa;
        border-radius: 12px;
        padding: 10px 15px;
        margin-bottom: 10px;
        border-left: 4px solid #ff8b94;
    }

    .ders-saat {
        font-weight: bold;
        color: #d15661;
        margin-right: 15px;
    }

    .ders-adi {
        font-size: 1.1rem;
        flex-grow: 1;
    }

    .form-control-custom {
        border-radius: 12px;
        border: 1px solid #ffdae0;
    }

        .form-control-custom:focus {
            border-color: #fbc2eb;
            box-shadow: 0 0 10px rgba(251, 194, 235, 0.4);
        }
</style>

<div class="container mt-4 mb-5">
    <h2 class="text-center mb-4 sayfa-baslik">📚 Ders Programım</h2>

    <div class="row justify-content-center mb-5">
        <div class="col-md-10">
            <div class="ekleme-kutusu">
                <h5 class="text-center text-muted mb-3" style="font-weight: bold;">Yeni Bir Çalışma Planı Ekle ✍️</h5>
                <form action="/Home/DersEkle" method="post" class="row g-3 justify-content-center align-items-end">
                    <div class="col-md-3">
                        <label class="form-label" style="font-size: 0.9rem; font-weight: bold;">Gün</label>
                        <select name="gun" class="form-select form-control-custom" required>
                            <option value="" disabled selected>Gün Seç...</option>
                            @foreach (var g in gunler)
                            {
                                <option value="@g">@g</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" style="font-size: 0.9rem; font-weight: bold;">Saat Aralığı</label>
                        <input type="text" name="saat" class="form-control form-control-custom" placeholder="Örn: 14:00 - 15:30" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" style="font-size: 0.9rem; font-weight: bold;">Hangi Ders / Konu?</label>
                        <input type="text" name="dersAdi" class="form-control form-control-custom" placeholder="Örn: C# Programlama" required>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn text-white w-100" style="background-color: #8fa0c9; border-radius: 12px; font-weight: bold; padding: 10px;">Kaydet 🚀</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="row">
        @foreach (var gun in gunler)
        {
            // O güne ait dersleri saatine göre alfabetik sıralayarak alıyoruz
            var oGunkuDersler = Model.Where(d => d.Gun == gun).OrderBy(d => d.Saat).ToList();

            if (oGunkuDersler.Count > 0)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="gun-karti">
                        <h4 class="gun-baslik text-center">@gun</h4>

                        @foreach (var ders in oGunkuDersler)
                        {
                            <div class="ders-satiri">
                                <span class="ders-saat">🕒 @ders.Saat</span>
                                <span class="ders-adi">@ders.DersAdi</span>
                                <a href="/Home/DersSil/@ders.Id" class="text-danger" style="text-decoration: none; font-size: 1.2rem;" title="Sil">❌</a>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>