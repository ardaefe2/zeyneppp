@model List<ZeynepsNotebook.Models.FilmDiziItem>

@{
    ViewData["Title"] = "İzlenecekler Listemiz";
}

<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@600&family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Nunito', sans-serif;
        color: #4a4a4a;
        background-image: url('/images/sinema.png?v=1') !important;
        background-size: cover !important;
        background-position: center !important;
        background-attachment: fixed !important;
    }

    .sayfa-baslik { font-family: 'Caveat', cursive; font-size: 4rem; color: #d15661; text-shadow: 2px 2px 5px rgba(0,0,0,0.1); }

    .ekleme-kutusu { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border-radius: 20px; padding: 25px; border: 2px dashed #ff8b94; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }

    ..liste-karti {
        background: rgba(255, 255, 255, 0.85); /* Arka plan hafifçe görünsün diye şeffaflık verdik */
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: 0.3s;
        height: 100%;
        border-top: 5px solid #ffdae0;
    }
    .liste-karti:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.12); }

    .kart-baslik { font-family: 'Caveat', cursive; font-size: 2.5rem; border-bottom: 2px dashed #eee; padding-bottom: 10px; margin-bottom: 15px; }

    .item-satiri { display: flex; justify-content: space-between; align-items: center; background: #fafafa; border-radius: 12px; padding: 12px 15px; margin-bottom: 10px; border-left: 4px solid #fbc2eb; transition: background 0.3s; }
    .item-satiri:hover { background: #fff0f5; }

    .item-ikon { font-size: 1.5rem; margin-right: 15px; }
    .item-adi { font-size: 1.15rem; flex-grow: 1; font-weight: bold; color: #555; }

    .form-control-custom { border-radius: 12px; border: 1px solid #ffdae0; }
    .form-control-custom:focus { border-color: #ff8b94; box-shadow: 0 0 10px rgba(255, 139, 148, 0.3); }

    .btn-sil { text-decoration: none; font-size: 1.2rem; margin-left: 10px; transition: transform 0.2s; display: inline-block; }
    .btn-sil:hover { transform: scale(1.2); }
</style>

<div class="container mt-4 mb-5">
    <h2 class="text-center mb-4 sayfa-baslik">🎬 İzlenecekler 🍿</h2>

    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <div class="ekleme-kutusu">
                <h5 class="text-center text-muted mb-3" style="font-weight: bold;">Listeye Yeni Bir Şey Ekle ✍️</h5>
                <form action="/Home/FilmEkle" method="post" class="row g-3 justify-content-center align-items-end">
                    <div class="col-md-7">
                        <label class="form-label" style="font-size: 0.9rem; font-weight: bold;">Film / Dizi Adı</label>
                        <input type="text" name="baslik" class="form-control form-control-custom" placeholder="Örn: The Office, Interstellar..." required autocomplete="off">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" style="font-size: 0.9rem; font-weight: bold;">Türü</label>
                        <select name="tur" class="form-select form-control-custom" required>
                            <option value="Film">🎬 Film</option>
                            <option value="Dizi">📺 Dizi</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn text-white w-100" style="background-color: #ff8b94; border-radius: 12px; font-weight: bold; padding: 10px;">Ekle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="liste-karti" style="border-top-color: #fbc2eb;">
                <h4 class="kart-baslik text-center" style="color: #a6c1ee;">⏳ Sırada Bekleyenler</h4>
                @foreach (var item in Model.Where(m => !m.IzlendiMi))
                {
                    <div class="item-satiri">
                        <span class="item-ikon">@(item.Tur == "Film" ? "🎬" : "📺")</span>
                        <span class="item-adi">@item.Baslik</span>
                        <div>
                            <a href="/Home/FilmDurumu/@item.Id" class="btn btn-sm btn-outline-success" style="border-radius: 10px; font-weight:bold;">İzledik ✔️</a>
                            <a href="/Home/FilmSil/@item.Id" class="btn-sil" title="Sil">❌</a>
                        </div>
                    </div>
                }
                @if (!Model.Any(m => !m.IzlendiMi))
                {
                    <p class="text-muted text-center mt-3">Liste boş, hemen yeni bir şeyler ekleyin! 🍿</p>
                }
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="liste-karti" style="border-top-color: #b2ad7f;">
                <h4 class="kart-baslik text-center" style="color: #b2ad7f;">✔️ İzleyip Bitirdiklerimiz</h4>
                @foreach (var item in Model.Where(m => m.IzlendiMi))
                {
                    <div class="item-satiri" style="opacity: 0.7; background: #f0f0f0; border-left-color: #ccc;">
                        <span class="item-ikon">@(item.Tur == "Film" ? "🎬" : "📺")</span>
                        <span class="item-adi"><del>@item.Baslik</del></span>
                        <div>
                            <a href="/Home/FilmDurumu/@item.Id" class="btn btn-sm btn-outline-secondary" style="border-radius: 10px;">Geri Al ↩️</a>
                            <a href="/Home/FilmSil/@item.Id" class="btn-sil" title="Sil">❌</a>
                        </div>
                    </div>
                }
                @if (!Model.Any(m => m.IzlendiMi))
                {
                    <p class="text-muted text-center mt-3">Henüz birlikte bir şey izlemediniz mi? 👀</p>
                }
            </div>
        </div>
    </div>
</div>