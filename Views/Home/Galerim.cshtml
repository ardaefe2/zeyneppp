@model List<ZeynepsNotebook.Models.ResimItem>

@{
    ViewData["Title"] = "Galerim";
}

<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">

<style>
    /* İŞTE KESİN ÇÖZÜM: Kendi klasörümüzden çekiyoruz */
    html, body {
        font-family: 'Nunito', sans-serif !important;
        color: #4a4a4a !important;
        background-color: #fdfaf2 !important;
        background-image: url('/images/cicek.jpg') !important; /* <- Değişen kısım burası */
        background-size: cover !important;
        background-position: center !important;
        background-attachment: fixed !important;
    }

    /* Diğer tasarımlarımız aynen duruyor */
    .galeri-baslik {
        font-family: 'Caveat', cursive;
        font-size: 4.5rem;
        color: #fff;
        text-shadow: 2px 2px 8px rgba(0,0,0,0.4);
        animation: titlePulse 2s ease-in-out infinite;
    }

    @@keyframes titlePulse {
        0% {
            transform: scale(1);
            text-shadow: 2px 2px 5px rgba(255,139,148,0.4);
        }

        50% {
            transform: scale(1.02);
            text-shadow: 2px 2px 12px rgba(255,139,148,0.7);
        }

        100% {
            transform: scale(1);
            text-shadow: 2px 2px 5px rgba(255,139,148,0.4);
        }
    }

    .yukleme-alani {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        padding: 25px;
        border-radius: 25px;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        border: 2px solid rgba(251, 194, 235, 0.6);
    }

    .form-control-custom {
        border-radius: 15px;
        border: 1px solid #ffdae0;
        background-color: #fff;
        transition: 0.3s;
    }

        .form-control-custom:focus {
            box-shadow: 0 0 10px rgba(255, 139, 148, 0.3);
            border-color: #ff8b94;
        }

    .btn-yukle-custom {
        border-radius: 15px;
        font-weight: bold;
        background: linear-gradient(45deg, #ff8b94, #ffdae0);
        color: white;
        border: none;
        padding: 10px 25px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(255, 139, 148, 0.3);
    }

        .btn-yukle-custom:hover {
            background: linear-gradient(45deg, #ffdae0, #ff8b94);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(255, 139, 148, 0.5);
            color: white;
        }

    .resim-cercevesi {
        position: relative;
        padding: 15px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(5px);
        border-radius: 25px;
        border: 2px solid rgba(251, 194, 235, 0.8);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        transition: all 0.3s ease;
        overflow: hidden;
    }

        .resim-cercevesi:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 15px 35px rgba(251, 194, 235, 0.6);
            border-color: rgba(251, 194, 235, 1);
        }

    .galeri-resim {
        width: 100%;
        height: 250px;
        object-fit: cover;
        border-radius: 20px;
        border: 1px solid #fbc2eb;
    }

    .resim-cercevesi::before, .resim-cercevesi::after {
        position: absolute;
        font-size: 1.8rem;
        font-family: 'Caveat', cursive;
        opacity: 0.8;
        transition: 0.3s;
    }

    .resim-cercevesi::before {
        top: 5px;
        left: 8px;
        content: '♥️';
        color: #ff8b94;
    }

    .resim-cercevesi::after {
        bottom: 5px;
        right: 8px;
        content: '🌸';
        color: #8fa0c9;
    }

    .col-md-4:nth-of-type(3n+1) .resim-cercevesi::before {
        content: '💖';
    }

    .col-md-4:nth-of-type(3n+1) .resim-cercevesi::after {
        content: '✨';
    }

    .col-md-4:nth-of-type(3n+2) .resim-cercevesi::before {
        content: '🌟';
    }

    .col-md-4:nth-of-type(3n+2) .resim-cercevesi::after {
        content: '🦋';
    }

    .col-md-4:nth-of-type(3n+3) .resim-cercevesi::before {
        content: '🎀';
    }

    .col-md-4:nth-of-type(3n+3) .resim-cercevesi::after {
        content: '🦄';
    }

    .resim-cercevesi:hover::before, .resim-cercevesi:hover::after {
        transform: scale(1.2);
        opacity: 1;
    }

    .sil-butonu {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(255, 139, 148, 0.9);
        color: white;
        border-radius: 50%;
        width: 35px;
        height: 35px;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
        font-weight: bold;
        z-index: 10;
        transition: 0.3s;
        border: 2px solid rgba(255,255,255,0.8);
    }

        .sil-butonu:hover {
            background: rgb(255, 80, 95);
            color: white;
            transform: scale(1.1);
            box-shadow: 0 0 10px rgba(255,0,0,0.4);
        }
</style>

<div class="container mt-4 mb-5">
    <h2 class="text-center mb-4 galeri-baslik">📸 Galerim</h2>

    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="yukleme-alani text-center">
                <form action="/Home/ResimYukle" method="post" enctype="multipart/form-data" class="d-flex align-items-center justify-content-center gap-3">
                    <input type="file" name="yuklenenResim" class="form-control form-control-custom" accept="image/*" required style="max-width: 450px;">
                    <button type="submit" class="btn btn-yukle-custom">Anını ekle 💖</button>
                </form>
            </div>
        </div>
    </div>

    <div class="row">
        @if (Model == null || Model.Count == 0)
        {
            <div class="col-12 text-center mt-5">
                <div class="p-5" style="background: rgba(255,255,255,0.7); border-radius: 20px; border: 2px dashed #ff8b94; backdrop-filter: blur(5px);">
                    <h4 class="text-muted" style="font-family: 'Caveat', cursive; font-size: 3rem; color: #ff8b94 !important;">Henüz hiç anı eklenmemiş... 🌸</h4>
                    <p class="text-muted" style="font-size: 1.2rem; font-weight: bold;">Yukarıdaki butonu kullanarak ilk fotoğrafımızı yükleyebilirsin!</p>
                </div>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="resim-cercevesi">
                        <a href="/Home/ResimSil/@item.Id" class="sil-butonu" title="Bu anıyı sil">X</a>
                        <img src="@item.ResimYolu" class="galeri-resim" alt="Galeri Resmi">
                    </div>
                </div>
            }
        }
    </div>
</div>