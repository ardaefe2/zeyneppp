@model List<ZeynepsNotebook.Models.GeziItem>

@{
    ViewData["Title"] = "Gezilecek Yerlerimiz";
}

<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@600&family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Nunito', sans-serif;
        background-color: #fdfaf2;
        color: #4a4a4a;
        background-image: url('/images/gezi.jpg?v=1') !important;
        background-size: cover !important;
        background-position: center !important;
        background-attachment: fixed !important;
    }

    .sayfa-baslik {
        font-family: 'Caveat', cursive;
        font-size: 4rem;
        color: #78a2cc;
        text-shadow: 2px 2px 5px rgba(0,0,0,0.1);
    }

    .ekleme-kutusu {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 25px;
        border: 2px dashed #a6c1ee;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .liste-karti {
        background: rgba(255, 255, 255, 0.85); /* Arka planı hafif göstersin */
        backdrop-filter: blur(10px); /* Cam efekti */
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: 0.3s;
        height: 100%;
        border-top: 5px solid #a6c1ee;
    }

        .liste-karti:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
        }

    .kart-baslik {
        font-family: 'Caveat', cursive;
        font-size: 2.5rem;
        border-bottom: 2px dashed #eee;
        padding-bottom: 10px;
        margin-bottom: 15px;
    }

    .item-satiri {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fafafa;
        border-radius: 12px;
        padding: 12px 15px;
        margin-bottom: 10px;
        border-left: 4px solid #a6c1ee;
        transition: background 0.3s;
    }

        .item-satiri:hover {
            background: #f0f8ff;
        }

    .item-ikon {
        font-size: 1.5rem;
        margin-right: 15px;
    }

    .item-adi {
        font-size: 1.15rem;
        flex-grow: 1;
        font-weight: bold;
        color: #555;
    }

    .item-sehir {
        font-size: 0.9rem;
        color: #888;
        background: #eef2f5;
        padding: 3px 8px;
        border-radius: 8px;
        margin-left: 10px;
    }

    .form-control-custom {
        border-radius: 12px;
        border: 1px solid #cddcfa;
    }

        .form-control-custom:focus {
            border-color: #a6c1ee;
            box-shadow: 0 0 10px rgba(166, 193, 238, 0.3);
        }

    .btn-sil {
        text-decoration: none;
        font-size: 1.2rem;
        margin-left: 10px;
        transition: transform 0.2s;
        display: inline-block;
    }

        .btn-sil:hover {
            transform: scale(1.2);
        }
</style>

<div class="container mt-4 mb-5">
    <h2 class="text-center mb-4 sayfa-baslik">🌍 Gezilecek Yerler ✈️</h2>

    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <div class="ekleme-kutusu">
                <h5 class="text-center text-muted mb-3" style="font-weight: bold;">Rotamıza Yeni Bir Yer Ekle 🗺️</h5>
                <form action="/Home/GeziEkle" method="post" class="row g-3 justify-content-center align-items-end">
                    <div class="col-md-6">
                        <label class="form-label" style="font-size: 0.9rem; font-weight: bold;">Mekan / Müze / Sokak Adı</label>
                        <input type="text" name="yerAdi" class="form-control form-control-custom" placeholder="Örn: Galata Kulesi..." required autocomplete="off">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" style="font-size: 0.9rem; font-weight: bold;">Hangi Şehirde?</label>
                        <input type="text" name="sehir" class="form-control form-control-custom" placeholder="Örn: İstanbul" required autocomplete="off">
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn text-white w-100" style="background-color: #78a2cc; border-radius: 12px; font-weight: bold; padding: 10px;">Ekle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="liste-karti" style="border-top-color: #a6c1ee;">
                <h4 class="kart-baslik text-center" style="color: #78a2cc;">📍 Gitmeyi Hayal Ettiklerimiz</h4>
                @foreach (var item in Model.Where(m => !m.GidildiMi))
                {
                    <div class="item-satiri">
                        <span class="item-ikon">🎒</span>
                        <div style="flex-grow: 1;">
                            <span class="item-adi">@item.YerAdi</span>
                            <span class="item-sehir">@item.Sehir</span>
                        </div>
                        <div>
                            <a href="/Home/GeziDurumu/@item.Id" class="btn btn-sm btn-outline-primary" style="border-radius: 10px; font-weight:bold;">Gittik 📸</a>
                            <a href="/Home/GeziSil/@item.Id" class="btn-sil" title="Sil">❌</a>
                        </div>
                    </div>
                }
                @if (!Model.Any(m => !m.GidildiMi))
                {
                    <p class="text-muted text-center mt-3">Rota boş, ufuklara yelken açma vakti! ⛵</p>
                }
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="liste-karti" style="border-top-color: #b2ad7f;">
                <h4 class="kart-baslik text-center" style="color: #b2ad7f;">✔️ Keşfettiklerim</h4>
                @foreach (var item in Model.Where(m => m.GidildiMi))
                {
                    <div class="item-satiri" style="opacity: 0.7; background: #f0f0f0; border-left-color: #ccc;">
                        <span class="item-ikon">📌</span>
                        <div style="flex-grow: 1;">
                            <span class="item-adi"><del>@item.YerAdi</del></span>
                            <span class="item-sehir">@item.Sehir</span>
                        </div>
                        <div>
                            <a href="/Home/GeziDurumu/@item.Id" class="btn btn-sm btn-outline-secondary" style="border-radius: 10px;">Geri Al ↩️</a>
                            <a href="/Home/GeziSil/@item.Id" class="btn-sil" title="Sil">❌</a>
                        </div>
                    </div>
                }
                @if (!Model.Any(m => m.GidildiMi))
                {
                    <p class="text-muted text-center mt-3">Daha keşfedilecek çok yer var! 🌍</p>
                }
            </div>
        </div>
    </div>
</div>